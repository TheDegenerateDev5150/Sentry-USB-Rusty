#!/bin/bash
#
# sentryusb-pick-binary — select the best-tuned sentryusb binary for the
# running CPU. Runs as ExecStartPre before sentryusb.service starts, so
# the daemon always launches via the best binary the hardware can run.
#
# The decision is recorded both in journalctl AND in
# /opt/sentryusb/active-variant (one line, the matched suffix) so the
# in-app self-updater can re-download the same variant on update.
#
# Detection rules:
#   * armv7 userspace (32-bit Pi) → linux-armv7
#   * aarch64 with HWCAP_ATOMICS (LSE in /proc/cpuinfo Features) → linux-arm64-a76
#     ↳ Pi 5 (Cortex-A76), and any future ARMv8.1+ board
#   * aarch64 with CPU part 0xD08 (Cortex-A72) → linux-arm64-a72
#     ↳ Pi 4, Radxa ROCK 4C+ perf cluster
#   * any other aarch64 (catch-all, includes Cortex-A53) → linux-arm64-a53
#     ↳ Pi 3, Pi Zero 2 W, Radxa ZERO 3W, OrangePi Zero 2W
#
# Fallback chain: if the picked file doesn't exist on disk (older image
# missing a variant), fall back to a72 (broadest aarch64 compat), then
# to the unsuffixed legacy name for very old installs that pre-date
# this scheme.

set -u

INSTALL_DIR=/opt/sentryusb
CURRENT_LINK="${INSTALL_DIR}/sentryusb-current"
ACTIVE_FILE="${INSTALL_DIR}/active-variant"
TAG="sentryusb-pick-binary"

log() { logger -t "$TAG" -- "$1" 2>/dev/null || echo "$TAG: $1" >&2; }

detect_variant() {
    # Userspace arch takes precedence — a 64-bit kernel may host a 32-bit
    # userspace where the aarch64 dynamic linker doesn't exist, in which
    # case an aarch64 binary won't load even though /proc/cpuinfo looks
    # arm64-capable. dpkg --print-architecture is the authoritative answer
    # on Debian-derived Pi OS.
    if command -v dpkg >/dev/null 2>&1; then
        case "$(dpkg --print-architecture 2>/dev/null)" in
            armhf) echo "linux-armv7"; return ;;
            armel)
                # armv6 (original Pi Zero W / Pi 1) is no longer supported.
                # Fall through so the fallback chain has a chance to find
                # an installed binary, but log the situation loudly.
                log "armel userspace detected; armv6 builds are no longer produced"
                ;;
            arm64) ;; # fall through to aarch64 sub-detection
            *) ;;    # fall through too — let uname decide
        esac
    fi

    case "$(uname -m)" in
        armv7l) echo "linux-armv7"; return ;;
        armv6l)
            log "armv6l kernel detected; armv6 builds are no longer produced"
            ;;
        aarch64) ;;
        *)
            # Unknown — return the broadest aarch64 binary as a guess.
            echo "linux-arm64-a72"
            return
            ;;
    esac

    # aarch64 sub-detection. The Features line in /proc/cpuinfo lists the
    # HWCAP names the kernel exported for this CPU. "atomics" indicates LSE
    # (ARMv8.1+ Large System Extensions) — only present on Cortex-A76 and
    # newer in our hardware spread. The a76 build also keeps the ARMv8
    # Cryptographic Extension enabled (the Pi 5 implements it), so require
    # the "aes" hwcap too — a future v8.1+ board without crypto must get
    # the a72 build (plain v8.0+crc) instead of SIGILLing in SHA/AES code.
    if grep -qE '^Features.*\batomics\b' /proc/cpuinfo \
        && grep -qE '^Features.*\baes\b' /proc/cpuinfo; then
        echo "linux-arm64-a76"
        return
    fi

    # CPU part 0xD08 is Cortex-A72 (Pi 4's BCM2711). Match anywhere in the
    # file because big.LITTLE SoCs like RK3399 (ROCK 4C+) report multiple
    # CPU part lines — presence of any A72 core is enough to use the
    # A72-tuned binary.
    if grep -qE '^CPU part[[:space:]]*:[[:space:]]*0x[dD]08' /proc/cpuinfo; then
        echo "linux-arm64-a72"
        return
    fi

    # Default for aarch64: A53-tuned. Covers Pi 3, Pi Zero 2 W,
    # Allwinner H618 boards (Radxa ZERO 3W, OrangePi Zero 2W).
    echo "linux-arm64-a53"
}

DETECTED="$(detect_variant)"
PICKED="$DETECTED"
PICKED_PATH="${INSTALL_DIR}/sentryusb-${PICKED}"

# Fallback chain — if the preferred variant isn't on disk, walk back through
# safer choices. Last resort is the unsuffixed legacy filename in case the
# image was built before this scheme.
if [ ! -x "$PICKED_PATH" ]; then
    log "preferred variant ${PICKED} not installed at ${PICKED_PATH}, walking fallbacks"
    for fallback in linux-arm64-a72 linux-arm64-a53 linux-armv7; do
        if [ -x "${INSTALL_DIR}/sentryusb-${fallback}" ]; then
            PICKED="$fallback"
            PICKED_PATH="${INSTALL_DIR}/sentryusb-${fallback}"
            log "fell back to ${fallback}"
            break
        fi
    done
fi

if [ ! -x "$PICKED_PATH" ]; then
    # Last-ditch: legacy single-binary install at /opt/sentryusb/sentryusb.
    if [ -x "${INSTALL_DIR}/sentryusb" ] && [ ! -L "${INSTALL_DIR}/sentryusb" ]; then
        PICKED="legacy"
        PICKED_PATH="${INSTALL_DIR}/sentryusb"
        log "no per-CPU binaries found, falling back to legacy ${PICKED_PATH}"
    else
        log "FATAL: no sentryusb binary found under ${INSTALL_DIR}"
        exit 1
    fi
fi

# Atomic symlink swap — ln -sfn keeps the old link reachable until rename
# completes, so a concurrent systemd ExecStart wouldn't dereference a
# half-written link.
ln -sfn "$PICKED_PATH" "$CURRENT_LINK"

# Record what this CPU NEEDS (the detected variant) — NOT what we ended
# up running. The fallback pick above reflects what happened to be on
# disk, and recording it poisons every downstream consumer that trusts
# this file (updater, startup migration, awake_start's one-shot fetch):
# they'd keep DOWNLOADING the fallback variant forever even though the
# right one is a URL away. Same reason "legacy" must never land here —
# it isn't a release suffix and 404s every download built from it.
# Best-effort write — failure here doesn't block startup, the updater
# just falls back to re-detection on its own.
if [ -n "$DETECTED" ]; then
    printf '%s\n' "$DETECTED" > "$ACTIVE_FILE" 2>/dev/null || true
fi

log "selected variant=${PICKED} (detected=${DETECTED:-unknown}) path=${PICKED_PATH}"

# ── Aux binaries: telemetry sampler + BLE action CLI ──
#
# These live at fixed paths under /root/bin (sentryusb-telemetry.service's
# ConditionPathExists and run/awake_start both reference them there), but
# like the main binary they are per-CPU-tuned builds. Manage them the same
# way: per-variant copies under /opt/sentryusb, with /root/bin as a symlink
# this picker re-points at every boot.
#
# This is the fix for the wrong-variant SIGILL crash-loop (issue #88):
# previously whatever variant landed in /root/bin stayed there forever, so
# moving an SD card between Pi models (or a bad suffix at install time)
# left a binary the CPU can't run — e.g. an a76 build's baked-in LSE
# atomics / crypto instructions SIGILL on a Pi 4's Cortex-A72 — with no
# self-heal, while the main binary silently corrected itself each boot.
#
# Legacy installs: if no per-variant copies exist under /opt/sentryusb
# (image predates this scheme and the OTA updater hasn't run since), leave
# /root/bin alone — a regular file there is the only copy we have.
mkdir -p /root/bin 2>/dev/null || true
for name in sentryusb-tesla-telemetry sentryusb-ble-action; do
    AUX_PATH="${INSTALL_DIR}/${name}-${PICKED}"
    if [ ! -x "$AUX_PATH" ]; then
        # Same fallback chain as the main binary. a72 is safe on every
        # aarch64 board we support (ARMv8.0 baseline, no LSE/crypto baked).
        for fallback in linux-arm64-a72 linux-arm64-a53 linux-armv7; do
            if [ -x "${INSTALL_DIR}/${name}-${fallback}" ]; then
                AUX_PATH="${INSTALL_DIR}/${name}-${fallback}"
                log "${name}: preferred variant ${PICKED} not installed, falling back to ${fallback}"
                break
            fi
        done
    fi
    if [ -x "$AUX_PATH" ]; then
        ln -sfn "$AUX_PATH" "/root/bin/${name}"
        log "${name} -> ${AUX_PATH}"
    fi
done

exit 0
